wp-content/uploads/
wp-content/upgrade/
wp-content/cache/
wp-content/backup/
wp-content/backups/
wp-content/wpforms/

# Plugins/themes tiers (gerer via composer ou install manuelle)
wp-content/plugins/akismet/
wp-content/plugins/hello.php
wp-content/plugins/woocommerce/
wp-content/plugins/wp-simple-pay/
wp-content/plugins/mailpoet/

# Logs et debug
wp-content/debug.log
*.log
debug.log
error_log
error.log

# Coeur WP (ne devrait pas etre dans le repo, mais au cas ou)
wp-admin/
wp-includes/
wp-*.php
!wp-content/

