# ─────────────────────────────────────────────────────────────────
# WordPress — fichiers sensibles
# ─────────────────────────────────────────────────────────────────
# Identifiants DB + AUTH_KEY/NONCE_KEY/etc — JAMAIS dans git
wp-config.php
wp-config-local.php
wp-config-staging.php
wp-config-production.php
wp-config-backup.php
wp-config.bak
.htaccess
.htpasswd

# Variables d'environnement
.env
.env.*
!.env.example

# Cles, certificats, secrets
*.pem
*.key
*.cert
*.crt
*.p12
secrets.json
credentials.json

# ─────────────────────────────────────────────────────────────────
# WordPress — dossiers a exclure
# ─────────────────────────────────────────────────────────────────
